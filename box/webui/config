EOF
)"
}

cmd_set_config() {
    local key="$1"
    shift
    local value="$*"

    require_key "$key" "set-config"
    config_set "$key" "$value"

    emit_ok "set-config" "{\"key\":\"$(json_escape "$key")\",\"value\":\"$(json_escape "$(config_get_clean "$key")")\"}"
}

cmd_toggle() {
    local key="$1"
    local value="$2"

    case "$value" in
        0|1) ;;
        *) emit_error "toggle value must be 0 or 1" "toggle" ;;
    esac

    validate_toggle_request "$key" "$value"
    config_set_numeric "$key" "$value"
    emit_ok "toggle" "{\"key\":\"$(json_escape "$key")\",\"value\":$value}"
}

cmd_set_number() {
    local key="$1"
    local value="$2"

    [ -n "$value" ] || emit_error "missing numeric value" "set-number"
    config_set_numeric "$key" "$value"
    emit_ok "set-number" "{\"key\":\"$(json_escape "$key")\",\"value\":$value}"
}

# box.webui 配置文件读写
# 管理 box.config / tproxy.conf 的读取、修改、校验

source_box_config() {
    [ -f "$BOX_CONFIG_FILE" ] || emit_error "box config file not found: $BOX_CONFIG_FILE" "config-read"
    . "$BOX_CONFIG_FILE"
}

source_tproxy_config() {
    [ -f "$TPROXY_CONFIG_FILE" ] || emit_error "tproxy config file not found: $TPROXY_CONFIG_FILE" "config-read"
    . "$TPROXY_CONFIG_FILE"
}

source_all_configs() {
    source_box_config
    source_tproxy_config
}

config_file_for_key() {
    local key="$1"

    if grep -q "^$key=" "$TPROXY_CONFIG_FILE" 2>/dev/null; then
        printf '%s' "$TPROXY_CONFIG_FILE"
        return 0
    fi

    if grep -q "^$key=" "$BOX_CONFIG_FILE" 2>/dev/null; then
        printf '%s' "$BOX_CONFIG_FILE"
        return 0
    fi

    return 1
}

require_key() {
    [ -n "$1" ] || emit_error "missing config key" "$2"
    validate_key_name "$1" "$2"
}

config_has_key() {
    local target_file
    target_file="$(config_file_for_key "$1")" || return 1
    grep -q "^$1=" "$target_file"
}

config_get_raw() {
    local target_file
    target_file="$(config_file_for_key "$1")" || return 1
    sed -n "s/^$1=//p" "$target_file" | head -n 1
}

config_get_clean() {
    local value
    value="$(config_get_raw "$1")"
    case "$value" in
        \"*\")
            value="${value#\"}"
            value="${value%\"}"
            ;;
        \'*\')
            value="${value#\'}"
            value="${value%\'}"
            ;;
    esac
    printf '%s' "$value"
}

replace_config_line() {
    local target_file="$1"
    local key="$2"
    local replacement="$3"
    local tmp_file="${target_file}.tmp.$$"

    awk -v key="$key" -v replacement="$replacement" '
        index($0, key "=") == 1 {
            print replacement
            next
        }
        { print }
    ' "$target_file" > "$tmp_file" || emit_error "failed to update config" "config-write"

    mv "$tmp_file" "$target_file" || emit_error "failed to replace config" "config-write"
}

config_set() {
    local key="$1"
    local value="$2"
    local shell_quoted
    local target_file

    require_key "$key" "set-config"
    target_file="$(config_file_for_key "$key")" || emit_error "unknown config key: $key" "set-config"

    shell_quoted="$(shell_quote_value "$value")"
    replace_config_line "$target_file" "$key" "${key}=${shell_quoted}"
}

config_set_numeric() {
    local key="$1"
    local value="$2"
    local target_file

    require_key "$key" "set-number"
    target_file="$(config_file_for_key "$key")" || emit_error "unknown config key: $key" "set-number"
    case "$value" in
        ''|*[!0-9-]*)
            emit_error "numeric value required for $key" "set-number"
            ;;
    esac
    replace_config_line "$target_file" "$key" "${key}=${value}"
}

validate_toggle_request() {
    local key="$1"
    local value="$2"

    [ "$value" = "1" ] || return 0

    case "$key" in
        BYPASS_CN_IP)
            if ! command_exists ipset; then
                emit_error "ipset command not found, cannot enable BYPASS_CN_IP" "toggle"
            fi
            if ! kernel_feature_enabled "IP_SET"; then
                emit_error "kernel does not support CONFIG_IP_SET, cannot enable BYPASS_CN_IP" "toggle"
            fi
            if ! kernel_feature_enabled "NETFILTER_XT_SET"; then
                emit_error "kernel does not support CONFIG_NETFILTER_XT_SET, cannot enable BYPASS_CN_IP" "toggle"
            fi
            ;;
        PROXY_IPV6)
            if [ "$(config_get_clean "PROXY_MODE")" = "2" ]; then
                if ! kernel_feature_enabled "IP6_NF_NAT"; then
                    emit_error "kernel does not support CONFIG_IP6_NF_NAT, cannot enable PROXY_IPV6 in REDIRECT mode" "toggle"
                fi
                if ! kernel_feature_enabled "IP6_NF_TARGET_REDIRECT"; then
                    emit_error "kernel does not support CONFIG_IP6_NF_TARGET_REDIRECT, cannot enable PROXY_IPV6 in REDIRECT mode" "toggle"
                fi
            fi
            ;;
    esac
}

